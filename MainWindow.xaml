<Window x:Class="WpfCybersecurityChatbot.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Cybersecurity Awareness Chatbot"
        Height="650"
        Width="520"
        WindowStartupLocation="CenterScreen"
        Background="#071A2E">

    <Grid Margin="12">

        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="2*"/>
        </Grid.RowDefinitions>

        <Border Grid.Row="0"
                Background="#0B2A4A"
                CornerRadius="12"
                Padding="12"
                Margin="0,0,0,10">

            <StackPanel>

                <TextBlock Text="🔒 Cybersecurity Awareness Chatbot"
                           FontSize="20"
                           FontWeight="Bold"
                           Foreground="#7FDBFF"
                           HorizontalAlignment="Center"/>

                <TextBlock x:Name="QuizModeIndicator"
                           Text=""
                           FontSize="12"
                           Foreground="#00B4D8"
                           HorizontalAlignment="Center"
                           Margin="0,5,0,0"/>

            </StackPanel>

        </Border>

        <Border Grid.Row="1"
                Background="#0B2A4A"
                CornerRadius="12"
                Padding="10"
                Margin="0,0,0,10">

            <ScrollViewer x:Name="ChatScroll"
                          VerticalScrollBarVisibility="Auto">

                <TextBlock x:Name="ChatHistory"
                           FontSize="14"
                           Foreground="White"
                           TextWrapping="Wrap"/>

            </ScrollViewer>

        </Border>

        <Grid Grid.Row="2"
              Margin="0,0,0,10">

            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="95"/>
            </Grid.ColumnDefinitions>

            <TextBox x:Name="InputBox"
                     Height="38"
                     Padding="10"
                     FontSize="14"
                     VerticalContentAlignment="Center"
                     Background="#0B2A4A"
                     Foreground="White"
                     BorderBrush="#1E5A8A"
                     KeyDown="InputBox_KeyDown"/>

            <Button Grid.Column="1"
                    Content="Send"
                    Height="38"
                    Margin="10,0,0,0"
                    Background="#00B4D8"
                    Foreground="Black"
                    FontWeight="Bold"
                    Click="SendButton_Click"/>

        </Grid>

        <Grid Grid.Row="3">

            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="2*"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <Border Grid.Column="0"
                    Background="#0B2A4A"
                    CornerRadius="12"
                    Padding="12"
                    Margin="0,0,8,0">

                <StackPanel>

                    <TextBlock Text="Task Assistant"
                               Foreground="#7FDBFF"
                               FontWeight="Bold"
                               FontSize="14"/>

                    <TextBlock Text="Ask about passwords, phishing, scams, privacy and cybersecurity."
                               Foreground="White"
                               Margin="0,6,0,12"
                               TextWrapping="Wrap"/>

                    <TextBlock Text="Quick Quiz"
                               Foreground="#7FDBFF"
                               FontWeight="Bold"
                               Margin="0,5,0,5"/>

                    <Border Background="#071A2E"
                            CornerRadius="8"
                            Padding="8"
                            Margin="0,0,0,10">

                        <StackPanel>

                            <TextBlock x:Name="QuizStatusText"
                                       Text="Status: Ready"
                                       Foreground="#00B4D8"
                                       FontSize="12"/>

                            <TextBlock x:Name="QuizScoreText"
                                       Text="Score: 0/0"
                                       Foreground="White"
                                       FontSize="12"/>

                            <TextBlock Text="Type 'quiz' to start"
                                       Foreground="#7FDBFF"
                                       FontSize="11"
                                       Opacity="0.8"/>

                        </StackPanel>

                    </Border>

                    <Border Background="#0F3A5A"
                            CornerRadius="8"
                            Padding="8">

                        <StackPanel>

                            <TextBlock Text="Current Question"
                                       Foreground="#7FDBFF"
                                       FontWeight="Bold"
                                       FontSize="12"/>

                            <TextBlock x:Name="QuizQuestionPreview"
                                       Text="No active quiz"
                                       Foreground="White"
                                       TextWrapping="Wrap"
                                       FontSize="12"/>

                        </StackPanel>

                    </Border>

                </StackPanel>

            </Border>

            <Border Grid.Column="1"
                    Background="#0B2A4A"
                    CornerRadius="12"
                    Padding="12"
                    Margin="8,0,0,0">

                <StackPanel>

                    <TextBlock Text="Security Reminder"
                               Foreground="#7FDBFF"
                               FontWeight="Bold"
                               FontSize="14"/>

                    <TextBlock Text="✔ Use strong passwords&#10;✔ Enable 2FA&#10;✔ Keep software updated"
                               Foreground="White"
                               Margin="0,8,0,12"/>

                    <Button Content="Clear Chat"
                            Height="30"
                            Margin="0,5"
                            Background="#1E5A8A"
                            Foreground="White"
                            Click="ClearChat_Click"/>

                    <Button Content="View Last Response"
                            Height="30"
                            Margin="0,5"
                            Background="#1E5A8A"
                            Foreground="White"
                            Click="SpeakLastResponse_Click"/>

                    <Button Content="Exit"
                            Height="30"
                            Margin="0,5"
                            Background="#D9534F"
                            Foreground="White"
                            Click="Exit_Click"/>

                </StackPanel>

            </Border>

        </Grid>

    </Grid>

</Window>