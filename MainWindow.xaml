<Window x:Class="WpfApp1.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
               Title="Cybersecurity Chatbot" Height="600" Width="400">
    <Border Padding="10">
        <StackPanel>
         
        

            <TextBlock Text="Chatbot" FontWeight="Bold" Margin="0 10"/>
            <TextBox Background="#fff" Padding="2" Margin="10 1 10 10" Height="252"/>

            <!--User Input-->
            <TextBlock Text="User Input"/>

            <TextBox Padding="2"/>

            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="2*"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <!--Task Assistant-->
                <StackPanel Grid.Column="0" Margin="0 0 10 0">
                    <TextBlock Text="Task Assistant"/>
                    <TextBox Background="#fff" Padding="2"/>
                    <TextBlock Text="Quiz"/>
                    <TextBox Background="#fff" Padding="2"/>

                </StackPanel>

                <!--Reminder-->
                <StackPanel Grid.Column="1">
                    <TextBlock Text="Reminder"/>
                    <TextBox Background="#fff" Padding="2"/>
                    
                    <Grid>

                        <Grid.ColumnDefinitions>

                            <ColumnDefinition Width ="*"/>
                            <ColumnDefinition Width ="*"/>


                        </Grid.ColumnDefinitions>

                        <Button Margin="0 10 10 0"  Grid.Column="0" Content ="Apply"/>
                        <Button Margin="0 10 10 0" Grid.Column="1" Content="Reset"/>

                    </Grid>
                    <Button Margin="0 10 10 0" Content="Exit"/>

                </StackPanel>


            </Grid>

        </StackPanel>
    </Border>
</Window>

